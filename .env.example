# ============================================================
# Environment Configuration
# Copy this file to .env and fill in your API keys
# ============================================================

# --- LLM Provider ---
LLM_PROVIDER=google_vertex            # google_vertex | google | openai
LLM_MODEL=gpt-4o                      # Model identifier (OpenAI fallback)
GEMINI_MODEL=gemini-2.5-pro           # Gemini model for Vertex AI
LLM_TEMPERATURE=0.2                   # Sampling temperature

# --- API Keys ---
OPENAI_API_KEY=sk-your-openai-key-here
#GOOGLE_API_KEY=your-google-api-key-here
VERTEX_API_KEY=your-vertex-api-key-here

# --- GCP / Vertex AI ---
GCP_PROJECT_ID=your-gcp-project-id-here
GCP_LOCATION=us-central1

# --- Search Provider ---
SEARCH_PROVIDER=tavily               # tavily | serpapi
TAVILY_API_KEY=tvly-your-tavily-key-here
SERPAPI_API_KEY=your-serpapi-key-here

# --- Agent Configuration ---
MAX_RETRIES=2                        # Max Red Team retry loops per use case
MAX_SEARCH_RESULTS=5                 # Results per search query
MAX_USE_CASES=5                      # Number of use cases to identify

# --- Logging ---
LOG_LEVEL=INFO                       # DEBUG | INFO | WARNING | ERROR
LOG_FORMAT=json                      # json | console
